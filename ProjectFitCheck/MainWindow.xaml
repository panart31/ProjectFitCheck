<Window x:Class="NutritionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FitCheck - Умный фитнес-трекер"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Цветовая палитра -->
        <Color x:Key="PrimaryColor">#7E57C2</Color>
        <Color x:Key="PrimaryDarkColor">#5E35B1</Color>
        <Color x:Key="PrimaryLightColor">#B39DDB</Color>

        <!-- Стили кнопок -->
        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#7E57C2" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Padding"
                    Value="24,14" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стили для текстовых полей -->
        <Style x:Key="ModernTextBox"
               TargetType="TextBox">
            <Setter Property="Background"
                    Value="#FAFAFA" />
            <Setter Property="BorderBrush"
                    Value="#E0E0E0" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="16,12" />
            <Setter Property="FontSize"
                    Value="14" />
        </Style>

        <!-- Стили для карточек -->
        <Style x:Key="InteractiveCard"
               TargetType="Border">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="CornerRadius"
                    Value="12" />
            <Setter Property="BorderBrush"
                    Value="#E0E0E0" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Margin"
                    Value="8,12" />
            <Setter Property="Padding"
                    Value="28" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2"
                                      BlurRadius="10"
                                      Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Верхняя панель -->
        <Border Background="#7E57C2"
                Height="72"
                VerticalAlignment="Top">
            <Grid>
                <TextBlock Text="FitCheck"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="28,0" />
            </Grid>
        </Border>

        <!-- Основное содержимое будет добавлено в MainWindow.xaml.cs -->
        <Grid Margin="0,72,0,0"
              x:Name="MainContentGrid" />
    </Grid>
</Window>